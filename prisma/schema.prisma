// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Note {
  id         String   @id @default(cuid())
  userId     String // Supabase auth user id (owner)
  type       String   @default("text") // "text" | "photo"
  title      String?
  content    String? // markdown, may contain [[wikilinks]]
  imagePath  String? // bare filename (local) or full Blob URL (cloud)
  categoryId String?
  canvasX    Float    @default(0)
  canvasY    Float    @default(0)
  isStub     Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  outgoingLinks Link[] @relation("source")
  incomingLinks Link[] @relation("target")

  @@index([userId])
  @@index([categoryId])
  @@index([createdAt])
}

model Category {
  id        String   @id @default(cuid())
  userId    String // Supabase auth user id (owner)
  name      String
  color     String
  createdAt DateTime @default(now())

  notes Note[]

  @@unique([userId, name])
  @@index([userId])
}

model Link {
  id           String   @id @default(cuid())
  userId       String // Supabase auth user id (owner) — always matches the notes it joins
  sourceNoteId String
  targetNoteId String
  kind         String   @default("wikilink") // "wikilink" | "manual"
  createdAt    DateTime @default(now())

  sourceNote Note @relation("source", fields: [sourceNoteId], references: [id], onDelete: Cascade)
  targetNote Note @relation("target", fields: [targetNoteId], references: [id], onDelete: Cascade)

  @@unique([sourceNoteId, targetNoteId, kind])
  @@index([userId])
}
